    { "pad_id": "F1", "use": "default", "soc_pin": "USB0_RX_N", "as": "USB_RX_N", "instance": "USB0" },
    { "pad_id": "E1", "use": "default", "soc_pin": "USB0_RX_P", "as": "USB_RX_P", "instance": "USB0" },
    { "pad_id": "I1", "use": "default", "soc_pin": "USB0_TX_N", "as": "USB_TX_N", "instance": "USB0" },
