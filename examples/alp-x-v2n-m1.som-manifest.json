    { "pad_id": "B47", "use": "default", "soc_pin": "PCIE0_REFCLK_N", "as": "PCIE_CLK_N", "instance": "PCIE0" },
    { "pad_id": "A47", "use": "default", "soc_pin": "PCIE0_REFCLK_P", "as": "PCIE_CLK_P", "instance": "PCIE0" },
