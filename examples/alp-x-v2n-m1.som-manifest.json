{
  "som_manifest_version": 1,
  "id": "ALP-X-V2N-M1",
  "version": "0.1.0",
  "description": "Reference SoM manifest snippet for ALP-X-V2N-M1 on E1M-X (45x65). Pairs Renesas RZ/V2N (CA55 + CM33 + DRP-AI3) with a DeepX M1 NPU companion. Routes the standard's primary functions on most pads; alt-uses GPIO on a handful for board-level signalling.",
  "implements": {
    "spec_id": "E1M-X",
    "spec_version": "1.0",
    "spec_repo": "https://github.com/alpCaner/e1m-spec"
  },
  "silicon": [
    {
      "role": "primary",
      "vendor": "Renesas",
      "family": "RZ/V2N",
      "part": "R9A09G057",
      "notes": "Cortex-A55 application + Cortex-M33 real-time, with DRP-AI3 accelerator."
    },
    {
      "role": "accelerator",
      "vendor": "DeepX",
      "family": "DX-M1",
      "part": "DX-M1",
      "notes": "Connected via PCIe to the primary; no E1M pads are routed directly to this part."
    },
    {
      "role": "pmic",
      "vendor": "Renesas",
      "family": "Multi-channel PMIC",
      "part": "RAA215300"
    }
  ],
  "routes": [
    { "pad_id": "A1", "use": "default", "soc_pin": "GND" },
    { "pad_id": "T1", "use": "default", "soc_pin": "5V_IN", "as": "POWER_5V0" },
    { "pad_id": "U1", "use": "default", "soc_pin": "5V_IN", "as": "POWER_5V0" },
    { "pad_id": "W1", "use": "default", "soc_pin": "VDDIO_1V8", "as": "POWER_VIO_OUT" },

    { "pad_id": "Y2", "use": "default", "soc_pin": "MD_BOOT_0", "as": "BOOT", "instance": "BOOT0" },
