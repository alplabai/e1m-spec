{
  "som_manifest_version": 1,
  "id": "E1M-V2M101",
  "version": "0.1.0",
  "description": "Reference SoM manifest snippet for E1M-V2M101 — Alp Lab E1M-X V2N-M1 family member (Renesas RZ/V2N + DeepX M1). Two SKUs in the family (E1M-V2M101 / E1M-V2M102) differ in memory tier (32/32 vs 64/128 Gbit). Sister family E1M-X V2N (E1M-V2N101 / E1M-V2N102) is the same module without DeepX M1. Routes the standard's primary functions on most pads; alt-uses GPIO on a handful for board-level signalling.",
  "implements": {
    "spec_id": "E1M-X",
    "spec_version": "1.0",
    "spec_repo": "https://github.com/alplabai/e1m-spec"
  },
  "family": "E1M-X V2N-M1",
  "family_skus": ["E1M-V2M101", "E1M-V2M102"],
  "sibling_family": {
    "name": "E1M-X V2N",
    "skus": ["E1M-V2N101", "E1M-V2N102"],
    "delta": "Same module without the DeepX M1 accelerator. PCIE0_* pads are then exposed externally rather than shared with the on-module M1."
  },
  "silicon": [
    {
      "role": "primary",
      "vendor": "Renesas",
      "family": "RZ/V2N",
      "part": "R9A09G056N44GBG#AC0",
      "notes": "4x Cortex-A55 @ 1.8 GHz + Cortex-M33 @ 200 MHz; DRP-AI3 (4 TOPS at the V2N grade; chip family rated up to 15 TOPS); Arm Mali-C55 ISP; Arm Mali-G31 GPU; H.264/H.265 codec."
    },
    {
      "role": "io_mcu",
      "vendor": "GigaDevice",
      "family": "GD32G553",
      "part": "GD32G553",
      "notes": "Separate on-module Arm Cortex-M33 @ 216 MHz, distinct from the Cortex-M33 embedded inside the RZ/V2N. Supervises power-rail sequencing alongside the DA9292 PMIC and orchestrates on-module peripherals during boot and low-power states."
    },
    {
      "role": "accelerator",
      "vendor": "DeepX",
      "family": "DX-M1",
      "part": "DX-M1",
      "notes": "Standalone AI accelerator, up to 25 TOPS. Companion memory: 2x LPDDR5X + SPI NAND. Attached internally via PCIe; not routed to additional E1M-X pads."
    },
    {
      "role": "pmic",
      "vendor": "Renesas",
      "family": "DA9292",
      "part": "DA9292",
      "notes": "Multi-channel PMIC for RZ/V2N."
    },
    {
      "role": "ethernet_phy",
      "vendor": "Realtek",
      "family": "RTL8211F",
      "part": "RTL8211FDI-VD-CG",
      "notes": "1 GbE PHY. Two instances on the SoM, one per E1M-X ETHn_* group."
    },
    {
      "role": "wifi_ble",
      "vendor": "Murata",
      "family": "Type2FY",
      "part": "LBEE5HY2FY",
      "notes": "Wi-Fi 6 + BLE 5.4 combo module based on Infineon CYW55513."
    }
  ],
  "_routes_format_note": "soc_pin uses the Renesas RZ/V2N datasheet's functional pin name (e.g. 'RIIC0_SCL0', 'TCK_SWCLK', 'MD_BOOT0'). soc_pin_bga is the BGA package coordinate of that same pin from R9A09G056N44GBG Pin Out.csv. For pads that go through an on-module PHY (Ethernet, Wi-Fi, CAN), soc_pin is the PHY's pin name and soc_via names the PHY chip.",
  "routes": [
    { "pad_id": "A1", "use": "default", "soc_pin": "VSS" },
    { "pad_id": "T1", "use": "default", "soc_pin": "VDD_5V_IN_BOARD", "as": "POWER_5V0", "soc_note": "Board-level 5 V input; on-module PMIC (Renesas DA9292) derives all SoC rails." },
    { "pad_id": "U1", "use": "default", "soc_pin": "VDD_5V_IN_BOARD", "as": "POWER_5V0" },
    { "pad_id": "W1", "use": "default", "soc_pin": "VDDIO_1V8_OUT", "as": "POWER_VIO_OUT", "soc_note": "Module-side 1.8 V I/O reference rail; sourced from on-module PMIC." },

    { "pad_id": "Y2",  "use": "default", "soc_pin": "MD_BOOT0", "soc_pin_bga": "AG21", "as": "BOOT", "instance": "BOOT0" },
    { "pad_id": "X2",  "use": "default", "soc_pin": "MD_BOOT1", "soc_pin_bga": "AF20", "as": "BOOT", "instance": "BOOT1" },
    { "pad_id": "X1",  "use": "default", "soc_pin": "MD_BOOT2", "soc_pin_bga": "AG20", "as": "BOOT", "instance": "BOOT2", "soc_note": "Strapped to 1 on the V2N reference SoM (per §6.4 of E1M-STD-1.0)." },
    { "pad_id": "Y1",  "use": "default", "soc_pin": "MD_BOOT4", "soc_pin_bga": "AD22", "as": "BOOT", "instance": "BOOT3", "soc_note": "E1M-X pad BOOT3 maps to the Renesas MD_BOOT4 strap on V2N (the chip has BOOT0/1/2/4; there is no MD_BOOT3). Selects boot CPU: high = CA55, low = CM33." },

    { "pad_id": "AL1", "use": "default", "soc_pin": "TRSTn",      "as": "JTAG_NRST", "instance": "JTAG0" },
    { "pad_id": "AJ1", "use": "default", "soc_pin": "TCK_SWCLK",  "soc_pin_bga": "AE24", "as": "JTAG_TCK", "instance": "JTAG0" },
    { "pad_id": "AJ2", "use": "default", "soc_pin": "TDI",        "as": "JTAG_TDI", "instance": "JTAG0" },
    { "pad_id": "AK2", "use": "default", "soc_pin": "TDO",        "as": "JTAG_TDO", "instance": "JTAG0" },
    { "pad_id": "AK1", "use": "default", "soc_pin": "TMS_SWDIO",  "soc_pin_bga": "AG24", "as": "JTAG_TMS", "instance": "JTAG0" },

    { "pad_id": "C1",  "use": "default", "soc_pin": "USB20_DM",   "as": "USB_DM",  "instance": "USB0" },
    { "pad_id": "B1",  "use": "default", "soc_pin": "USB20_DP",   "soc_pin_bga": "V28",  "as": "USB_DP",  "instance": "USB0" },
    { "pad_id": "F1",  "use": "default", "soc_pin": "USB30_RX0M", "soc_pin_bga": "Y27",  "as": "USB_RX_N", "instance": "USB0" },
    { "pad_id": "E1",  "use": "default", "soc_pin": "USB30_RX0P", "soc_pin_bga": "Y28",  "as": "USB_RX_P", "instance": "USB0" },
    { "pad_id": "I1",  "use": "default", "soc_pin": "USB30_TX0M", "soc_pin_bga": "W28",  "as": "USB_TX_N", "instance": "USB0" },
    { "pad_id": "H1",  "use": "default", "soc_pin": "USB30_TX0P", "soc_pin_bga": "W29",  "as": "USB_TX_P", "instance": "USB0" },

    { "pad_id": "AR56", "use": "default", "soc_pin": "MDI_TXN_or_RXN", "soc_via": "Realtek RTL8211FDI", "as": "ETH_DA_N", "instance": "ETH0", "soc_note": "E1M-X ETH differential pads connect to the on-module Realtek RTL8211FDI PHY's MDI side; the Renesas RZ/V2N drives the PHY over RGMII (not exposed on E1M-X)." },
    { "pad_id": "AQ56", "use": "default", "soc_pin": "MDI_TXP_or_RXP", "soc_via": "Realtek RTL8211FDI", "as": "ETH_DA_P", "instance": "ETH0" },

    { "pad_id": "B47", "use": "default", "soc_pin": "PCIE_REFCLKN0", "soc_pin_bga": "G26", "as": "PCIE_CLK_N", "instance": "PCIE0", "soc_note": "PCIe controller is shared on V2N-M1: the on-module DeepX M1 sits on PCIE0 internally; external PCIE0_* pads are then bridge-shared." },
    { "pad_id": "A47", "use": "default", "soc_pin": "PCIE_REFCLKP0", "soc_pin_bga": "G25", "as": "PCIE_CLK_P", "instance": "PCIE0" },
    { "pad_id": "B42", "use": "default", "soc_pin": "PCIE_RXDNL0",   "soc_pin_bga": "F27", "as": "PCIE_RX0_N", "instance": "PCIE0" },
    { "pad_id": "A42", "use": "default", "soc_pin": "PCIE_RXDPL0",   "soc_pin_bga": "F28", "as": "PCIE_RX0_P", "instance": "PCIE0" },

    { "pad_id": "AB2", "use": "default", "soc_pin": "RSCI0_RXD0_MISO0_SCL0", "soc_pin_bga": "AD10", "as": "UART_RX", "instance": "UART0", "soc_note": "Renesas port pin P51." },
    { "pad_id": "AA2", "use": "default", "soc_pin": "RSCI0_TXD0_MOSI0_SDA0", "soc_pin_bga": "AE10", "as": "UART_TX", "instance": "UART0", "soc_note": "Renesas port pin P50." },

    { "pad_id": "AH1", "use": "default", "soc_pin": "RIIC0_SCL0", "soc_pin_bga": "AJ7", "as": "I2C_SCL", "instance": "I2C0", "soc_note": "Renesas port pin P31." },
    { "pad_id": "AH2", "use": "default", "soc_pin": "RIIC0_SDA0", "soc_pin_bga": "AH7", "as": "I2C_SDA", "instance": "I2C0", "soc_note": "Renesas port pin P30." },

    { "pad_id": "AQ19", "use": "default", "soc_pin": "I3C_SCL30", "soc_pin_bga": "AH21", "as": "I3C_SCL", "instance": "I3C0", "soc_note": "Renesas port pin P21." },
    { "pad_id": "AR19", "use": "default", "soc_pin": "I3C_SDA30", "soc_pin_bga": "AJ21", "as": "I3C_SDA", "instance": "I3C0", "soc_note": "Renesas port pin P20." },

    { "pad_id": "T64", "use": "default", "soc_pin": "CSI0_DATA0N", "soc_pin_bga": "T2", "as": "MIPI_CSI2_DATA0_N", "instance": "CSI0" },
    { "pad_id": "T63", "use": "default", "soc_pin": "CSI0_DATA0P", "soc_pin_bga": "T1", "as": "MIPI_CSI2_DATA0_P", "instance": "CSI0" },
    { "pad_id": "R64", "use": "default", "soc_pin": "CSI0_CLKN",   "soc_pin_bga": "R3", "as": "MIPI_CSI2_CLK_N",   "instance": "CSI0" },
    { "pad_id": "R63", "use": "default", "soc_pin": "CSI0_CLKP",   "soc_pin_bga": "R2", "as": "MIPI_CSI2_CLK_P",   "instance": "CSI0" },

    { "pad_id": "AF2", "use": "alt", "soc_pin": "GPIO_(silicon-specific)", "as": "GPIO" },
    { "pad_id": "AG2", "use": "alt", "soc_pin": "GPIO_(silicon-specific)", "as": "GPIO" }
  ],
  "not_routed": [
    "AN1", "AP1", "AR1"
  ]
}
