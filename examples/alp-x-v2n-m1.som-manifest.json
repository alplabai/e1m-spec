    { "pad_id": "Y1", "use": "default", "soc_pin": "MD_BOOT_3", "as": "BOOT", "instance": "BOOT3" },

    { "pad_id": "AL1", "use": "default", "soc_pin": "TRSTn", "as": "JTAG_NRST", "instance": "JTAG0" },
    { "pad_id": "AJ1", "use": "default", "soc_pin": "TCK", "as": "JTAG_TCK", "instance": "JTAG0" },
